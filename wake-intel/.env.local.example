# Copy to .env.local and fill in. .env.local is git-ignored.
#
# This is a NO-AUTH internal tool: the login flow was removed. All server-side
# reads/writes go through the Supabase SERVICE-ROLE key (see lib/supabase/server.ts
# and lib/supabase/admin.ts), which bypasses RLS. Those clients are only ever
# created in Server Components / Server Actions / Route Handlers and are never
# shipped to the browser, so the key is not exposed.

# ── Supabase — the project you are TARGETING for Wake Intel ─────────────────
# Project ref: achrsfeajyvqqcrjcxvr (name "33Health", SHARED, fe33_-prefixed).
# Do NOT point this at any other Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://achrsfeajyvqqcrjcxvr.supabase.co
# Anon/publishable key. Public, browser-safe. Used by lib/supabase/client.ts and
# components/run-actions.tsx (Bearer token when invoking edge functions).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key. Bypasses RLS — SERVER-ONLY. Powers every app read/write
# (no-auth) plus the seed script. SECRET — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase tooling (CLI / Management API / MCP) — NOT a runtime var ────────
# Personal access token (sbp_...). Only needed locally for the Supabase CLI,
# migrations, and the supabase MCP. Do NOT set this in Vercel.
SUPABASE_ACCESS_TOKEN=

# ── Email — monthly report delivery (generate-report edge function) ─────────
# IMPORTANT: these are SUPABASE EDGE FUNCTION SECRETS, not Vercel env vars.
# Set them with `supabase secrets set ...` (see DEPLOY.md §2). generate-report
# only sends mail when BOTH RESEND_API_KEY and REPORT_TO are set; otherwise it
# just returns the computed report JSON (safe to run pre-launch).
RESEND_API_KEY=
REPORT_TO=
REPORT_CC=
REPORT_FROM=Field Elevate Intel <intel@fieldelevate.com>

# ── Inert / legacy (no longer gates anything) ───────────────────────────────
# ALLOWED_EMAILS is NOT enforced anywhere now that auth is removed. It is read
# only by app/(app)/settings/page.tsx to display allowlist status. Leave empty.
ALLOWED_EMAILS=

# ── NOT used by the current code (reference only — safe to omit) ─────────────
# The NPPES and Wake County base URLs are HARDCODED constants inside the edge
# functions (enrich-therapy-provider, enrich-parcel), NOT read from env.
# APOLLO_API_KEY and APP_BASE_URL are not referenced anywhere in the codebase.
# NPPES_BASE_URL=https://npiregistry.cms.hhs.gov/api
# WAKE_PARCELS_BASE_URL=https://maps.wake.gov/arcgis/rest/services
# APOLLO_API_KEY=
# APP_BASE_URL=http://localhost:3000
